.program i2sin_left
.side_set 2

; Master-mode I2S RX, left-justified. Mirrors the timing of i2s_left.pio.
                    ;        /--- LRCLK
                    ;        |/-- BCLK
                    ;        ||
    nop               side 0b01
.wrap_target
    set y 14          side 0b01 [1]
bitloop1:
    nop               side 0b10 [2] ; Right channel first
    in pins 1         side 0b11
    jmp y-- bitloop1  side 0b11 [1]
    nop               side 0b10 [2]
    in pins 1         side 0b11
    set y 14          side 0b11 [1]
bitloop0:
    nop               side 0b00 [2] ; Then left channel
    in pins 1         side 0b01
    jmp y-- bitloop0  side 0b01 [1]
    nop               side 0b00 [2]
    in pins 1         side 0b01
.wrap
