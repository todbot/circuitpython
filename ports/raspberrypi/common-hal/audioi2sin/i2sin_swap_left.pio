.program i2sin_swap_left
.side_set 2

; Master-mode I2S RX, left-justified, with the LRCLK and BCLK pin order
; swapped (BCLK is the higher-numbered GPIO).
                    ;        /--- BCLK
                    ;        |/-- LRCLK
                    ;        ||
    nop               side 0b10
.wrap_target
    set y 14          side 0b10 [1]
bitloop1:
    nop               side 0b01 [2] ; Right channel first
    in pins 1         side 0b11
    jmp y-- bitloop1  side 0b11 [1]
    nop               side 0b01 [2]
    in pins 1         side 0b11
    set y 14          side 0b11 [1]
bitloop0:
    nop               side 0b00 [2] ; Then left channel
    in pins 1         side 0b10
    jmp y-- bitloop0  side 0b10 [1]
    nop               side 0b00 [2]
    in pins 1         side 0b10
.wrap
